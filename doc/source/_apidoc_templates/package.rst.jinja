{#
    COMMENT :
    ---------
    Création de la macro automodule.
    Appelle la directive `automodule` avec les options `options` pour générer
    automatiquement la documentation du module `modname` de C3PO.
#}
{%- macro automodule(modname, options) -%}
.. automodule:: {{ modname }}
{%- for option in options %}
   :{{ option }}:
{%- endfor %}
{%- endmacro %}
{#
    COMMENT :
    ---------
    Création de la macro toctree.
    Appelle la directive `toctree` pour générer une table des matières des sous-modules `docname`
    présents dans le package `pkgname`.
#}
{%- macro toctree(docnames) -%}
.. toctree::
   :maxdepth: 1
{% for docname in docnames %}
   {{ pkgname.split(".")[-1]+"/"+docname }}
{%- endfor %}
{%- endmacro %}
{#
    COMMENT :
    ---------
    Création de l'entête d'un package de C3PO.
#}
{%- if is_namespace %}
{{- [pkgname, "namespace"] | join(" ") | e | heading }}
{% else %}
{{- [pkgname, "package"] | join(" ") | e | heading }}
{% endif %}

{%- if is_namespace %}
.. py:module:: {{ pkgname }}
{% endif %}
{#
    COMMENT :
    ---------
    Génération automatique du module `pkgname` si le package est lui-même un module de C3PO.
#}
{%- if modulefirst and not is_namespace %}
{{ automodule(pkgname, automodule_options) }}
{% endif %}
{#
    COMMENT :
    ---------
    Création d'une table des matières si des sous-répertoires sont présents dans `pkgname`.
#}
{%- if subpackages %}
{{ toctree(subpackages) }}
{% endif %}
{#
    COMMENT :
    ---------
    Création d'une table des matières si des sous-modules sont présents dans `pkgname`.
#}
{%- if submodules %}
{% if separatemodules %}
{{ toctree(submodules) }}
{% else %}
{%- for submodule in submodules %}
{% if show_headings %}
{{- [submodule, "module"] | join(" ") | e | heading(2) }}
.. inheritance-diagram:: {{submodule}}
    :parts: 1
{% endif %}
{{ automodule(submodule, automodule_options) }}
{% endfor %}
{%- endif %}
{%- endif %}

{%- if not modulefirst and not is_namespace %}
{{ automodule(pkgname, automodule_options) }}
{% endif %}
